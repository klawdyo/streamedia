# Segredos obrigatórios — gere com: openssl rand -hex 32
UPLOAD_TOKEN_SECRET=
WEBHOOK_SECRET=
ADMIN_TOKEN=

# URL do backend principal para receber webhooks
WEBHOOK_URL=https://seu-backend.com/webhooks/media

# Tamanho máximo de upload em MB (padrão: 10)
MAX_UPLOAD_SIZE_MB=10

# Diretórios (dentro do container)
MEDIA_DIR=/media
UPLOAD_TMP_DIR=/media/.uploads
SQLITE_PATH=/data/media.db

# Fila de transcodificação
QUEUE_MAX_SIZE=50
TRANSCODE_WORKERS=1

# TTL do token de upload em horas (padrão: 6)
UPLOAD_TOKEN_TTL_H=6

# TTL máximo do token de reprodução em horas
PLAY_TOKEN_MAX_TTL_H=6

# Timeout de inatividade de upload em minutos (padrão: 10)
UPLOAD_IDLE_TIMEOUT_MIN=10

# Timeout de transcode travado em minutos (padrão: 30)
TRANSCODE_STUCK_MIN=30

# Número máximo de tentativas de transcode (padrão: 3)
MAX_TRANSCODE_ATTEMPTS=3

# Manter arquivo original após transcode? (padrão: false)
KEEP_ORIGINAL=false

# Porta HTTP do servidor (padrão: 3000)
PORT=3000

# Limite de requisições por minuto por IP (padrão: 60)
RATE_LIMIT_PER_MIN=60
