# Ambiente de execução — exposto em GET /api no campo "environment".
# Use "production" no servidor e "development" localmente. Se não definir,
# o padrão é "development".
ENV=development

# Segredos obrigatórios — gere com: openssl rand -hex 32
#
# ROOT_TOKEN: credencial única de gestão. O backend principal a apresenta em
#   Authorization: Bearer <ROOT_TOKEN> para iniciar uploads (/api/upload/init),
#   emitir URLs de play (/api/play/init), consultar status, listar e apagar.
#   Sem vínculo com dados — pode ser trocada a qualquer momento (basta mudar
#   aqui e reiniciar).
ROOT_TOKEN=
# WEBHOOK_URL: URL GLOBAL do backend principal para receber webhooks. OPCIONAL —
#   sem ela, nenhum webhook é enviado (os eventos do pipeline continuam
#   disponíveis ao vivo via SSE em GET /api/events). Quando definida, o
#   WEBHOOK_SECRET abaixo passa a ser obrigatório. Pode ser sobrescrita por
#   vídeo via o campo "webhook_url" no POST /api/upload/init (issue #20).
WEBHOOK_URL=
# WEBHOOK_SECRET: assina (HMAC) os webhooks enviados ao backend principal —
#   é o único segredo compartilhado entre os dois lados. Obrigatório apenas
#   quando WEBHOOK_URL está definida. Independe do destino (global ou por vídeo).
WEBHOOK_SECRET=
# DISCORD_WEBHOOK_URL: webhook do Discord para ALERTAS OPERACIONAIS internos
#   (issue #21) — falha de transcodificação, fila cheia, transcode travado e
#   aumento anormal de falhas consecutivas. OPCIONAL — sem ela, nenhum alerta é
#   enviado. Distinto dos webhooks de negócio acima (não recebe video ready).
DISCORD_WEBHOOK_URL=

# Tamanho máximo de upload em MB (padrão: 10)
MAX_UPLOAD_SIZE_MB=10

# Diretórios (dentro do container)
MEDIA_DIR=/media
UPLOAD_TMP_DIR=/media/.uploads
SQLITE_PATH=/data/media.db

# Fila de transcodificação
QUEUE_MAX_SIZE=50
TRANSCODE_WORKERS=1

# TTL do token de upload em segundos (padrão: 1200 = 20min).
# Issue #10 (T50): TTL unificado — não existe mais distinção scoped vs global.
UPLOAD_TOKEN_TTL=1200

# TTL do token de reprodução emitido por /api/play/init, em segundos
# (padrão: 3600 = 1h). O token é validado por lookup no banco.
PLAY_TOKEN_TTL=3600

# Timeout de inatividade de upload em segundos (padrão: 600 = 10min)
UPLOAD_IDLE_TIMEOUT=600

# Timeout de transcode travado em segundos (padrão: 1800 = 30min)
TRANSCODE_STUCK=1800

# Número máximo de tentativas de transcode (padrão: 3)
MAX_TRANSCODE_ATTEMPTS=3

# Manter arquivo original após transcode? (padrão: false)
KEEP_ORIGINAL=false

# Porta HTTP do servidor (padrão: 3000)
PORT=3000

# Limite de requisições por minuto por IP (padrão: 60)
RATE_LIMIT_PER_MIN=60
