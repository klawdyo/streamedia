# =========================================================
#            Streamedia — Variáveis de ambiente
# =========================================================
# As variáveis abaixo são ESSENCIAIS para o funcionamento do
# container. Configurações operacionais (workers, timeouts,
# tamanhos de upload, webhook URL, Discord, rate limit, TTLs
# de sessão/tokens) são gerenciadas via painel admin em
# /admin/config e persistidas no banco SQLite.
# =========================================================

# =========================================================
#  AMBIENTE
# =========================================================

# ENV — ambiente de execução.
#   "production"  → cookies de sessão com Secure=true (exige HTTPS)
#   "development" → cookies de sessão com Secure=false (HTTP local)
#   Exposto em GET /api no campo "environment".
#   Padrão: development.
ENV=development

# =========================================================
#  CREDENCIAIS DE GESTÃO
# =========================================================

# ROOT_TOKEN — credencial única de administração (OBRIGATÓRIA).
#   Apresentada no header Authorization: Bearer <ROOT_TOKEN> pelo
#   backend principal para iniciar uploads, emitir URLs de play,
#   consultar status, listar e apagar vídeos.
#   NÃO vinculada a nenhum dado de usuário — pode ser trocada a
#   qualquer momento (basta alterar e reiniciar o container).
#   Gere com: openssl rand -hex 32
ROOT_TOKEN=

# =========================================================
#  GOOGLE OAUTH 2.0
# =========================================================

# GOOGLE_CLIENT_ID — Client ID da aplicação OAuth 2.0 (OBRIGATÓRIO).
#   Obtido em: Google Cloud Console → APIs & Services → Credentials
#   → Create Credentials → OAuth client ID → Web application.
#   Sem esta variável, o login no painel admin NÃO funciona.
GOOGLE_CLIENT_ID=

# GOOGLE_CLIENT_SECRET — Client Secret do OAuth 2.0 (OBRIGATÓRIO).
#   Segredo gerado junto com o Client ID acima.
#   NUNCA exposto ao frontend.
#   Sem esta variável, o login no painel admin NÃO funciona.
GOOGLE_CLIENT_SECRET=

# NOTA: a URL de redirect OAuth NÃO é configurável por env.
# O servidor a constrói automaticamente a partir do domínio da
# requisição: https://<SEU_DOMINIO>/api/auth/google/callback
# Cadastre exatamente essa URL no Google Cloud Console:
#   APIs & Services → Credentials → seu OAuth 2.0 Client ID
#   → Authorized redirect URIs → Add URI.



# =========================================================
#  INFRAESTRUTURA
# =========================================================

# PORT — porta HTTP do servidor.
#   Padrão: 3000.
PORT=3000

# SQLITE_PATH — caminho do arquivo do banco SQLite.
#   Padrão: /data/media.db.
#   No Coolify, este arquivo fica no volume montado em /data.
SQLITE_PATH=/data/media.db

