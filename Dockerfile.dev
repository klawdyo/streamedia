# Dockerfile de desenvolvimento — hot reload com Air
# Usado pelo docker-compose.dev.yml para rodar o servidor Go com rebuild
# automático a cada alteração no código-fonte.

# Stage 1: build do frontend Vue (igual produção, mas com node_modules em cache)
FROM node:22-alpine AS ui-build
WORKDIR /app
COPY web/package.json web/package-lock.json ./
RUN npm install
COPY web/ ./
RUN npm run build

# Stage 2: ambiente de desenvolvimento Go com Air + FFmpeg
FROM golang:1.26-alpine

# FFmpeg para transcodificação + su-exec para entrypoint (igual produção)
RUN apk add --no-cache ffmpeg wget su-exec

# Air: live reload para Go
RUN go install github.com/air-verse/air@latest

WORKDIR /src

# Pre-download das dependências Go (cache do Docker — só refaz quando go.mod/go.sum mudam)
COPY go.mod go.sum ./
RUN go mod download

# Config do Air
COPY .air.toml ./

# Frontend já compilado (vem do stage 1, não depende do host)
COPY --from=ui-build /app/dist /app/web/dist

# Entrypoint de dev: inicia o Air com hot reload
# O código-fonte (cmd/, internal/) é montado via bind mount no docker-compose.dev.yml
CMD ["air", "-c", ".air.toml"]
